# WireGuard for iOS & macOS - Fastlane Configuration
#
# Prerequisites:
#   brew install fastlane go swiftlint xcodegen
#
# Quick start:
#   cp Sources/WireGuardApp/Config/Developer.xcconfig.template \
#      Sources/WireGuardApp/Config/Developer.xcconfig
#   # Edit Developer.xcconfig with your DEVELOPMENT_TEAM, APP_ID_IOS, APP_ID_MACOS
#   fastlane ios build
#

default_platform(:ios)

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------

XCODEPROJ = "WireGuard.xcodeproj"
API_KEY_JSON = File.expand_path("../fastlane/api_key.json")

def auth_xcargs
  return "-allowProvisioningUpdates" unless File.exist?(API_KEY_JSON)
  key = JSON.parse(File.read(API_KEY_JSON))
  # xcodebuild needs the raw .p8 file, not the JSON wrapper.
  # Extract the key into a temp file if we only have the JSON.
  p8_path = File.expand_path("../fastlane/AuthKey_#{key['key_id']}.p8")
  unless File.exist?(p8_path)
    File.write(p8_path, key['key'])
  end
  "-allowProvisioningUpdates" \
    " -authenticationKeyPath '#{p8_path}'" \
    " -authenticationKeyID '#{key['key_id']}'" \
    " -authenticationKeyIssuerID '#{key['issuer_id']}'"
end

# Parse Developer.xcconfig into a Hash (keys like APP_ID_IOS, APP_ID_MACOS, etc.)
def read_developer_xcconfig
  path = File.join(__dir__, "..", "Sources", "WireGuardApp", "Config", "Developer.xcconfig")
  values = {}
  return values unless File.exist?(path)
  File.readlines(path).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#") || line.start_with?("//")
    if line =~ /^(\w+)\s*=\s*(.+)$/
      values[$1] = $2.strip
    end
  end
  values
end

before_all do
  xcconfig = File.join(__dir__, "..", "Sources", "WireGuardApp", "Config", "Developer.xcconfig")
  unless File.exist?(xcconfig)
    UI.user_error!(
      "Developer.xcconfig not found. Copy the template first:\n" \
      "  cp Sources/WireGuardApp/Config/Developer.xcconfig.template " \
      "Sources/WireGuardApp/Config/Developer.xcconfig\n" \
      "Then fill in DEVELOPMENT_TEAM, APP_ID_IOS, and APP_ID_MACOS."
    )
  end

  # Regenerate Xcode project from project.yml (source of truth)
  project_yml = File.join(__dir__, "..", "project.yml")
  if File.exist?(project_yml)
    unless system("which xcodegen > /dev/null 2>&1")
      UI.user_error!("xcodegen is required but not installed. Install with: brew install xcodegen")
    end
    sh("cd .. && xcodegen generate")
  end
end

# ---------------------------------------------------------------------------
# iOS
# ---------------------------------------------------------------------------

platform :ios do
  desc "Build WireGuard for iOS (debug)"
  lane :build do
    build_app(
      project: XCODEPROJ,
      scheme: "WireGuardiOS",
      configuration: "Debug",
      skip_codesigning: true,
      skip_archive: true,
      skip_package_dependencies_resolution: true,
      destination: "generic/platform=iOS"
    )
  end

  desc "Build and install on connected iOS device"
  lane :device do
    build_app(
      project: XCODEPROJ,
      scheme: "WireGuardiOS",
      configuration: "Debug",
      export_method: "development",
      skip_profile_detection: true,
      skip_package_dependencies_resolution: true,
      xcargs: "-allowProvisioningUpdates"
    )
    install_on_device
  end

  desc "Build and install on device with failover testing enabled"
  lane :device_failover do
    build_app(
      project: XCODEPROJ,
      scheme: "WireGuardiOS",
      configuration: "Debug",
      export_method: "development",
      skip_profile_detection: true,
      skip_package_dependencies_resolution: true,
      xcargs: "-allowProvisioningUpdates SWIFT_ACTIVE_COMPILATION_CONDITIONS=\"DEBUG FAILOVER_TESTING\""
    )
    install_on_device
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    ensure_git_status_clean

    build_app(
      project: XCODEPROJ,
      scheme: "WireGuardiOS",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false,
      skip_package_dependencies_resolution: true,
      xcargs: auth_xcargs
    )

    upload_to_testflight(
      api_key_path: API_KEY_JSON,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      config_file: ".swiftlint.yml",
      raise_if_swiftlint_error: true
    )
  end

  desc "Register all App IDs and capabilities on the Apple Developer Portal"
  lane :register do
    config = read_developer_xcconfig
    app_id_ios = config["APP_ID_IOS"]
    app_id_macos = config["APP_ID_MACOS"]
    UI.user_error!("APP_ID_IOS not set in Developer.xcconfig") unless app_id_ios && !app_id_ios.empty?
    UI.user_error!("APP_ID_MACOS not set in Developer.xcconfig") unless app_id_macos && !app_id_macos.empty?

    key_json = JSON.parse(File.read(API_KEY_JSON))
    token = Spaceship::ConnectAPI::Token.create(
      key_id: key_json["key_id"],
      issuer_id: key_json["issuer_id"],
      filepath: File.expand_path("../fastlane/AuthKey_#{key_json['key_id']}.p8")
    )
    Spaceship::ConnectAPI.token = token

    bundles = [
      { identifier: app_id_ios,                          name: "WGnext",                    platform: "IOS",    capabilities: %w[APP_GROUPS NETWORK_EXTENSIONS] },
      { identifier: "#{app_id_ios}.network-extension",   name: "WGnext Network Extension",  platform: "IOS",    capabilities: %w[APP_GROUPS NETWORK_EXTENSIONS] },
      { identifier: "#{app_id_ios}.widget",              name: "WGnext Widget",             platform: "IOS",    capabilities: %w[APP_GROUPS] },
      { identifier: app_id_macos,                        name: "WGnext macOS",              platform: "MAC_OS", capabilities: %w[APP_GROUPS NETWORK_EXTENSIONS] },
      { identifier: "#{app_id_macos}.network-extension", name: "WGnext NE macOS",           platform: "MAC_OS", capabilities: %w[APP_GROUPS NETWORK_EXTENSIONS] },
      { identifier: "#{app_id_macos}.login-item-helper", name: "WGnext Login Helper macOS", platform: "MAC_OS", capabilities: %w[APP_GROUPS] },
    ]

    bundles.each do |info|
      bundle_id = Spaceship::ConnectAPI::BundleId.find(info[:identifier])
      if bundle_id
        UI.important("#{info[:identifier]} already registered")
      else
        bundle_id = Spaceship::ConnectAPI::BundleId.create(
          name: info[:name],
          identifier: info[:identifier],
          platform: info[:platform]
        )
        UI.success("Registered #{info[:identifier]}")
      end

      existing = Spaceship::ConnectAPI::BundleIdCapability.all(bundle_id_id: bundle_id.id)
      info[:capabilities].each do |cap_type|
        next if existing.any? { |c| c.capability_type == cap_type }
        Spaceship::ConnectAPI::BundleIdCapability.create(
          bundle_id_id: bundle_id.id,
          capability_type: cap_type,
          settings: []
        )
        UI.success("Enabled #{cap_type} on #{info[:identifier]}")
      end
    end
  end

  desc "Register new device by name and UDID"
  lane :add_device do |options|
    device_name = options[:name] || UI.input("Device name: ")
    device_udid = options[:udid] || UI.input("Device UDID: ")
    register_device(
      api_key_path: API_KEY_JSON,
      name: device_name,
      udid: device_udid
    )
  end

  desc "Sync development signing (via match)"
  lane :signing do
    match(type: "development")
  end

end

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------

platform :mac do
  desc "Build WireGuard for macOS (debug)"
  lane :build do
    build_mac_app(
      project: XCODEPROJ,
      scheme: "WireGuardmacOS",
      configuration: "Debug",
      skip_codesigning: true,
      skip_archive: true,
      skip_package_dependencies_resolution: true
    )
  end

  desc "Build and install WireGuard for macOS (debug)"
  lane :install do
    build_mac_app(
      project: XCODEPROJ,
      scheme: "WireGuardmacOS",
      configuration: "Debug",
      export_method: "development",
      skip_profile_detection: true,
      skip_package_dependencies_resolution: true,
      output_directory: "build",
      xcargs: auth_xcargs
    )
    install_mac_app
  end

  desc "Build and install with failover testing enabled"
  lane :install_failover do
    build_mac_app(
      project: XCODEPROJ,
      scheme: "WireGuardmacOS",
      configuration: "Debug",
      export_method: "development",
      skip_profile_detection: true,
      skip_package_dependencies_resolution: true,
      output_directory: "build",
      xcargs: "#{auth_xcargs} SWIFT_ACTIVE_COMPILATION_CONDITIONS=\"DEBUG FAILOVER_TESTING\""
    )
    install_mac_app
  end

  private_lane :install_mac_app do
    # build_mac_app sets PKG_OUTPUT_PATH (.app) and XCODEBUILD_ARCHIVE (.xcarchive)
    app_output = lane_context[SharedValues::PKG_OUTPUT_PATH]
    unless app_output && File.exist?(app_output)
      # Fall back to finding the .app inside the xcarchive
      archive = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
      if archive
        app_output = Dir.glob("#{archive}/Products/Applications/*.app").first
      end
    end
    UI.user_error!("Could not find built .app to install") unless app_output && File.exist?(app_output)
    sh("pkill -x WGnext || true")
    # Use osascript to get admin privileges for installing to /Applications
    sh("osascript -e 'do shell script \"rm -rf /Applications/WGnext.app && cp -R \\\"#{app_output}\\\" /Applications/\" with administrator privileges'")
    UI.success("Installed to /Applications/WGnext.app")
    sh("open /Applications/WGnext.app")
  end

  desc "Build WireGuard for macOS (release)"
  lane :release do
    build_mac_app(
      project: XCODEPROJ,
      scheme: "WireGuardmacOS",
      configuration: "Release",
      export_method: "developer-id",
      skip_package_dependencies_resolution: true
    )
  end
end
